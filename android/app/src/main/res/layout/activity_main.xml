<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_deep"
    tools:context=".MainActivity">

    <!-- Subtle Background Ambient Glow -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/gradient_bg" />

    <!-- Top Medical Banner -->
    <LinearLayout
        android:id="@+id/headerBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NEURAL-LIVER v2.0"
            android:textColor="@color/vibrant_cyan"
            android:letterSpacing="0.1"
            android:textSize="22sp"
            android:fontFamily="sans-serif-condensed-medium"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Volumetric Anomaly Diagnostic Suite"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:textAllCaps="true" />
    </LinearLayout>

    <!-- Glassmorphic Global Controls -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/controlCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#20FFFFFF"
        app:cardBackgroundColor="@color/surface_glass"
        app:layout_constraintTop_toBottomOf="@id/headerBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MODEL CONFIGURATION"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.05" />

            <Spinner
                android:id="@+id/spinnerModels"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="@color/white" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="#15FFFFFF" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnUpload"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="START NEW SCAN"
                android:textSize="14sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                app:icon="@android:drawable/ic_menu_upload"
                app:iconGravity="textStart"
                app:cornerRadius="16dp"
                app:backgroundTint="@color/button_pink" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Diagnostic Progress Section -->
    <LinearLayout
        android:id="@+id/loadingLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/controlCard"
        app:layout_constraintBottom_toTopOf="@id/resultScrollView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="@color/vibrant_cyan" />

        <TextView
            android:id="@+id/tvLoadingStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="AI ENGINE PROCESSING..."
            android:textColor="@color/vibrant_cyan"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Results Section Title -->
    <TextView
        android:id="@+id/tvResultLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:layout_marginTop="24dp"
        android:text="DIAGNOSTIC FEED"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:visibility="invisible"
        app:layout_constraintTop_toBottomOf="@id/controlCard"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Scrollable Diagnostic Results -->
    <ScrollView
        android:id="@+id/resultScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:fadeScrollbars="true"
        app:layout_constraintTop_toBottomOf="@id/tvResultLabel"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/llResultsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp" />
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>